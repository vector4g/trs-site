# Static asset cache policy — applied by any host that honours the
# Netlify/Cloudflare-Pages `_headers` convention. Emergent's production
# ingress reads this in static-SPA mode. The dev preview enforces the same
# policy via webpack-dev-server config in `craco.config.js`.
#
# Hashed CRA build artefacts are content-addressed (e.g., main.<hash>.js), so
# they can be cached forever — a deploy that changes the JS produces a new
# filename. The HTML shell at `/` and `/index.html` is intentionally short-
# cached so the next deploy ships immediately.

/static/*
  Cache-Control: public, max-age=31536000, immutable

/*.woff2
  Cache-Control: public, max-age=31536000, immutable

/*.png
  Cache-Control: public, max-age=86400

/*.jpg
  Cache-Control: public, max-age=86400

/*.svg
  Cache-Control: public, max-age=86400

/*.ico
  Cache-Control: public, max-age=86400

/favicon-16.png
  Cache-Control: public, max-age=86400

/favicon-32.png
  Cache-Control: public, max-age=86400

/apple-touch-icon.png
  Cache-Control: public, max-age=86400

/sitemap.xml
  Cache-Control: public, max-age=3600

/robots.txt
  Cache-Control: public, max-age=3600

/llms.txt
  Cache-Control: public, max-age=3600

/
  Cache-Control: public, max-age=0, must-revalidate

/index.html
  Cache-Control: public, max-age=0, must-revalidate
